@using GestionCalidad.Repositories
@inject IInspectionRepository Repository

@{
    ViewData["Title"] = "Inicio";
    var inspections = (await Repository.GetAllAsync()).ToList();
    var total = inspections.Count;
    var aprobadas = inspections.Count(i => i.Estado == "Aprobado");
    var rechazadas = inspections.Count(i => i.Estado == "Rechazado");
    var pendientes = inspections.Count(i => i.Estado == "Pendiente");
    var index = 1;
}

<div class="mb-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
            <h1 class="h3 fw-bold mb-1">Panel de Control</h1>
            <p class="text-muted small mb-0">Bienvenido al sistema de gestión de inspecciones de calidad</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Inspections" asp-action="Create" class="btn btn-navy shadow-sm">
                <i class="bi bi-plus-circle me-1"></i> Nueva Inspección
            </a>
            <a asp-controller="Inspections" asp-action="Dashboard" class="btn btn-outline-navy">
                <i class="bi bi-bar-chart me-1"></i> Dashboard
            </a>
        </div>
    </div>
    <div class="section-divider"></div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success border-0 rounded-3 shadow-sm d-flex align-items-center gap-2 py-3 mb-4" role="alert">
        <i class="bi bi-check-circle-fill fs-5"></i>
        <span>@TempData["Success"]</span>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3 mb-4">
    <div class="col-lg-3 col-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-3 d-flex align-items-center gap-3">
                <div style="background: rgba(26,35,50,0.08);" class="rounded-3 p-3">
                    <i class="bi bi-clipboard-data fs-4" style="color: var(--navy);"></i>
                </div>
                <div>
                    <div class="fs-3 fw-bold" style="color: var(--navy);">@total</div>
                    <div class="text-muted small">Total</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-3 d-flex align-items-center gap-3">
                <div style="background: rgba(39,174,96,0.1);" class="rounded-3 p-3">
                    <i class="bi bi-check-circle fs-4" style="color: var(--accent-green);"></i>
                </div>
                <div>
                    <div class="fs-3 fw-bold" style="color: var(--accent-green);">@aprobadas</div>
                    <div class="text-muted small">Aprobadas</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-3 d-flex align-items-center gap-3">
                <div style="background: rgba(231,76,60,0.1);" class="rounded-3 p-3">
                    <i class="bi bi-x-circle fs-4" style="color: var(--accent-red);"></i>
                </div>
                <div>
                    <div class="fs-3 fw-bold" style="color: var(--accent-red);">@rechazadas</div>
                    <div class="text-muted small">Rechazadas</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-3 col-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-3 d-flex align-items-center gap-3">
                <div style="background: rgba(243,156,18,0.1);" class="rounded-3 p-3">
                    <i class="bi bi-hourglass fs-4" style="color: var(--accent-amber);"></i>
                </div>
                <div>
                    <div class="fs-3 fw-bold" style="color: var(--accent-amber);">@pendientes</div>
                    <div class="text-muted small">Pendientes</div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (!inspections.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center py-5">
            <div class="mb-3" style="font-size: 4rem; color: #dee2e6;">
                <i class="bi bi-inbox"></i>
            </div>
            <h5 class="fw-bold mb-2">No hay inspecciones registradas</h5>
            <p class="text-muted small mb-3">Comience registrando una nueva inspección de calidad.</p>
            <a asp-controller="Inspections" asp-action="Create" class="btn btn-navy px-4">
                <i class="bi bi-plus-circle me-1"></i> Crear primera inspección
            </a>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center p-3">
            <h5 class="fw-bold mb-0 fs-6">
                <i class="bi bi-list-check me-2" style="color: var(--navy);"></i>Inspecciones Recientes
            </h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th class="ps-4" style="width: 50px;">#</th>
                            <th>Producto</th>
                            <th>Inspector</th>
                            <th>Fecha</th>
                            <th>Estado</th>
                            <th class="text-center pe-4" style="width: 150px;">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in inspections.OrderByDescending(i => i.FechaInspeccion))
                        {
                            <tr>
                                <td class="ps-4 text-muted fw-medium">@(index++)</td>
                                <td class="fw-medium">@Html.DisplayFor(m => item.Producto)</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <span style="background: rgba(26,35,50,0.08); color: var(--navy); width: 32px; height: 32px; font-size: 0.75rem; font-weight: 600;" class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0">
                                            @item.Inspector?.Split(' ').Select(s => s[0]).Take(2).Aggregate("", (a, b) => a + b)
                                        </span>
                                        <span>@Html.DisplayFor(m => item.Inspector)</span>
                                    </div>
                                </td>
                                <td class="text-muted">
                                    <i class="bi bi-calendar3 me-1"></i>@item.FechaInspeccion.ToString("dd/MM/yyyy")
                                </td>
                                <td>
                                    @if (item.Estado == "Aprobado")
                                    {
                                        <span class="badge badge-aprobado badge-modern">
                                            <i class="bi bi-check-circle me-1"></i>Aprobado
                                        </span>
                                    }
                                    else if (item.Estado == "Rechazado")
                                    {
                                        <span class="badge badge-rechazado badge-modern">
                                            <i class="bi bi-x-circle me-1"></i>Rechazado
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-pendiente badge-modern">
                                            <i class="bi bi-hourglass me-1"></i>Pendiente
                                        </span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <div class="btn-group btn-group-modern">
                                        <a asp-controller="Inspections" asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-navy" title="Ver detalles">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-controller="Inspections" asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-warning" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-controller="Inspections" asp-action="Delete" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-danger" title="Eliminar">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white border-top-0 p-3 text-end text-muted small">
            Mostrando @inspections.Count inspección@(inspections.Count != 1 ? "es" : "")
        </div>
    </div>
}
