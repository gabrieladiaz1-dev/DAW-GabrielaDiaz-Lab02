@model GestionCalidad.ViewModels.InspectionViewModel

@{
    ViewData["Title"] = "Editar Inspección";
}

<div class="mb-4">
    <h1 class="h3 fw-bold mb-1">Editar Inspección</h1>
    <p class="text-muted small mb-0">Modifique los datos de la inspección de calidad seleccionada</p>
    <div class="section-divider"></div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-3 py-2 d-none" id="validationSummary"></div>

                    <div class="row g-4 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Producto" class="form-label"></label>
                            <select asp-for="Producto" asp-items="Model.ProductosList" class="form-select">
                                <option value="">— Seleccione —</option>
                            </select>
                            <span asp-validation-for="Producto" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Inspector" class="form-label"></label>
                            <select asp-for="Inspector" asp-items="Model.InspectoresList" class="form-select">
                                <option value="">— Seleccione —</option>
                            </select>
                            <span asp-validation-for="Inspector" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-4 mb-3">
                        <div class="col-md-6">
                            <label asp-for="FechaInspeccion" class="form-label"></label>
                            <div class="input-group input-group-custom">
                                <span class="input-group-text"><i class="bi bi-calendar"></i></span>
                                <input asp-for="FechaInspeccion" class="form-control" type="date" />
                            </div>
                            <span asp-validation-for="FechaInspeccion" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Estado" class="form-label"></label>
                            <select asp-for="Estado" asp-items="Model.EstadosList" class="form-select">
                                <option value="">— Seleccione —</option>
                            </select>
                            <span asp-validation-for="Estado" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Observaciones" class="form-label"></label>
                        <textarea asp-for="Observaciones" class="form-control" rows="4" placeholder="Escriba los detalles de la inspección..."></textarea>
                        <span asp-validation-for="Observaciones" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2 justify-content-end pt-3 border-top">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">
                            <i class="bi bi-x-circle me-1"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-navy px-4">
                            <i class="bi bi-save me-1"></i> Guardar Cambios
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm" style="background: rgba(26,35,50,0.04); border: 1px solid rgba(26,35,50,0.1);">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3" style="color: var(--navy);"><i class="bi bi-pencil me-2"></i>Editando</h6>
                <p class="small text-muted mb-0">
                    Está modificando una inspección existente. Los cambios se guardarán al hacer clic en "Guardar Cambios".
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        $(function () {
            var summary = $("#validationSummary");
            $("form").on("invalid-form.validate", function () {
                summary.removeClass("d-none");
            });
            $("form").on("valid-form.validate", function () {
                summary.addClass("d-none");
            });
        });
    </script>
}
