@model GestionCalidad.Models.Inspection

@{
    ViewData["Title"] = "Detalles de Inspección";
}

<div class="mb-4">
    <h1 class="h3 fw-bold mb-1">Detalles de Inspección</h1>
    <p class="text-muted small mb-0">Información completa de la inspección seleccionada</p>
    <div class="section-divider"></div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="detail-label mb-1">Producto</div>
                        <div class="detail-value">@Html.DisplayFor(m => m.Producto)</div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-label mb-1">Inspector</div>
                        <div class="detail-value">@Html.DisplayFor(m => m.Inspector)</div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-label mb-1">Fecha de Inspección</div>
                        <div class="detail-value">@Model.FechaInspeccion.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-label mb-1">Estado</div>
                        <div class="detail-value">
                            @if (Model.Estado == "Aprobado")
                            {
                                <span class="badge badge-aprobado badge-modern">
                                    <i class="bi bi-check-circle me-1"></i>Aprobado
                                </span>
                            }
                            else if (Model.Estado == "Rechazado")
                            {
                                <span class="badge badge-rechazado badge-modern">
                                    <i class="bi bi-x-circle me-1"></i>Rechazado
                                </span>
                            }
                            else
                            {
                                <span class="badge badge-pendiente badge-modern">
                                    <i class="bi bi-hourglass me-1"></i>Pendiente
                                </span>
                            }
                        </div>
                    </div>
                    <div class="col-12">
                        <hr />
                        <div class="detail-label mb-1">Observaciones</div>
                        <p class="mb-0 mt-2">@Html.DisplayFor(m => m.Observaciones)</p>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-light border-0 p-4">
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-navy px-4">
                        <i class="bi bi-pencil me-1"></i> Editar
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-red px-4">
                        <i class="bi bi-trash me-1"></i> Eliminar
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4 ms-auto">
                        <i class="bi bi-arrow-left me-1"></i> Volver
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm" style="background: var(--navy);">
            <div class="card-body p-4 text-white text-center">
                <i class="bi bi-clipboard-check" style="font-size: 3rem; opacity: 0.8;"></i>
                <h6 class="fw-bold mt-3 mb-0">Inspección #@Model.Id</h6>
                <p class="small opacity-75 mb-0">@Model.Producto</p>
            </div>
        </div>

        <div class="card border-0 shadow-sm mt-3">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3" style="color: var(--navy);"><i class="bi bi-clock me-2"></i>Línea de Tiempo</h6>
                <ul class="list-unstyled small mb-0">
                    <li class="d-flex gap-3 mb-3">
                        <div style="background: rgba(26,35,50,0.08); color: var(--navy); width: 32px; height: 32px;" class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0">
                            <i class="bi bi-calendar-check"></i>
                        </div>
                        <div>
                            <div class="fw-medium">Registrada</div>
                            <div class="text-muted">@Model.FechaInspeccion.ToString("dd/MM/yyyy")</div>
                        </div>
                    </li>
                    <li class="d-flex gap-3">
                        <div style="background: rgba(39,174,96,0.1); color: var(--accent-green); width: 32px; height: 32px;" class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0">
                            <i class="bi bi-person-check"></i>
                        </div>
                        <div>
                            <div class="fw-medium">Inspector</div>
                            <div class="text-muted">@Model.Inspector</div>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>
